---
export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  schemaJson?: object | object[];
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const { title, description, canonicalUrl, schemaJson, breadcrumbs } = Astro.props;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;
const schemas = schemaJson
  ? Array.isArray(schemaJson) ? schemaJson : [schemaJson]
  : [];

const allSchemas = breadcrumbs && breadcrumbs.length > 0
  ? [...schemas, {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": b.name,
        "item": new URL(b.url, Astro.site).href,
      })),
    }]
  : schemas;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Calcolare Codice Fiscale</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:image" content={new URL('/og-image.svg', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Schema.org JSON-LD -->
    {allSchemas.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s).replace(/<\//g, '<\\/')} />
    ))}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- GTM placeholder: insert Google Tag Manager <script> here -->
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">

    <!-- Navbar -->
    <header class="bg-brand-blue text-white shadow-md">
      <nav aria-label="Navigazione principale" class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight hover:opacity-90 flex items-center gap-2">
          <span class="bg-white text-brand-blue px-2 py-0.5 rounded text-sm font-mono font-black">CF</span>
          <span class="hidden sm:inline">Calcolare Codice Fiscale</span>
        </a>
        <!-- Desktop nav -->
        <ul class="hidden sm:flex gap-5 text-sm font-medium">
          <li><a href="/codice-fiscale-inverso/" class="hover:underline opacity-90 hover:opacity-100">Inverso</a></li>
          <li><a href="/verifica-codice-fiscale/" class="hover:underline opacity-90 hover:opacity-100">Verifica</a></li>
          <li><a href="/come-si-calcola-codice-fiscale/" class="hover:underline opacity-90 hover:opacity-100">Come si calcola</a></li>
          <li><a href="/omocodia-codice-fiscale/" class="hover:underline opacity-90 hover:opacity-100">Omocodia</a></li>
        </ul>
        <!-- Mobile hamburger -->
        <button id="menu-btn" class="sm:hidden p-1.5 rounded hover:bg-white/10 transition-colors" aria-label="Apri menu" aria-expanded="false">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
    </header>

    <!-- Mobile overlay backdrop -->
    <div id="menu-overlay" class="fixed inset-0 bg-black/50 z-40 opacity-0 pointer-events-none transition-opacity duration-300" aria-hidden="true"></div>

    <!-- Mobile slide drawer -->
    <aside id="menu-drawer" class="fixed top-0 right-0 h-full w-72 max-w-[85vw] bg-white z-50 shadow-2xl translate-x-full transition-transform duration-300 flex flex-col" aria-label="Menu di navigazione">
      <!-- Drawer header -->
      <div class="bg-brand-blue text-white px-5 py-4 flex items-center justify-between shrink-0">
        <a href="/" class="flex items-center gap-2 font-bold">
          <span class="bg-white text-brand-blue px-2 py-0.5 rounded text-xs font-mono font-black">CF</span>
          Menu
        </a>
        <button id="menu-close" class="p-1 rounded hover:bg-white/10 transition-colors" aria-label="Chiudi menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <!-- Drawer nav -->
      <nav class="flex-1 overflow-y-auto p-5 space-y-6">
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-2 px-3">Strumenti</p>
          <ul class="space-y-0.5">
            <li><a href="/" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-800 hover:bg-blue-50 hover:text-brand-blue transition-colors">Calcola Codice Fiscale</a></li>
            <li><a href="/codice-fiscale-inverso/" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-800 hover:bg-blue-50 hover:text-brand-blue transition-colors">Codice Fiscale Inverso</a></li>
            <li><a href="/verifica-codice-fiscale/" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-800 hover:bg-blue-50 hover:text-brand-blue transition-colors">Verifica Codice Fiscale</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-2 px-3">Guide e Riferimenti</p>
          <ul class="space-y-0.5">
            <li><a href="/come-si-calcola-codice-fiscale/" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-800 hover:bg-blue-50 hover:text-brand-blue transition-colors">Come si Calcola</a></li>
            <li><a href="/omocodia-codice-fiscale/" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-800 hover:bg-blue-50 hover:text-brand-blue transition-colors">Omocodia</a></li>
            <li><a href="/tabelle-codice-fiscale/" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-800 hover:bg-blue-50 hover:text-brand-blue transition-colors">Tabelle di Riferimento</a></li>
            <li><a href="/codice-fiscale-stranieri/" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-800 hover:bg-blue-50 hover:text-brand-blue transition-colors">Nati all'Estero</a></li>
          </ul>
        </div>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="max-w-3xl mx-auto px-4 py-8 w-full flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 py-6 text-center text-sm text-gray-500 mt-auto">
      <p class="mb-1">
        Strumento gratuito per il calcolo del codice fiscale italiano —
        elaborazione secondo il D.M. 12/03/1974
      </p>
      <p class="flex justify-center flex-wrap gap-3 text-xs mt-1">
        <a href="/" class="hover:underline">Calcola CF</a>
        <span aria-hidden="true">·</span>
        <a href="/codice-fiscale-inverso/" class="hover:underline">Inverso</a>
        <span aria-hidden="true">·</span>
        <a href="/verifica-codice-fiscale/" class="hover:underline">Verifica</a>
        <span aria-hidden="true">·</span>
        <a href="/come-si-calcola-codice-fiscale/" class="hover:underline">Come si calcola</a>
        <span aria-hidden="true">·</span>
        <a href="/omocodia-codice-fiscale/" class="hover:underline">Omocodia</a>
        <span aria-hidden="true">·</span>
        <a href="/tabelle-codice-fiscale/" class="hover:underline">Tabelle</a>
        <span aria-hidden="true">·</span>
        <a href="/codice-fiscale-stranieri/" class="hover:underline">Stranieri</a>
      </p>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const overlay = document.getElementById('menu-overlay');
      const drawer = document.getElementById('menu-drawer');
      const closeBtn = document.getElementById('menu-close');

      function openMenu() {
        overlay.classList.remove('pointer-events-none');
        overlay.classList.add('opacity-100');
        drawer.classList.remove('translate-x-full');
        btn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        overlay.classList.add('pointer-events-none');
        overlay.classList.remove('opacity-100');
        drawer.classList.add('translate-x-full');
        btn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      btn.addEventListener('click', openMenu);
      closeBtn.addEventListener('click', closeMenu);
      overlay.addEventListener('click', closeMenu);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });
    </script>

  </body>
</html>

<style is:global>
  * { box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; }
</style>

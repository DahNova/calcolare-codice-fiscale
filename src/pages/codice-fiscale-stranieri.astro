---
import Layout from '../layouts/Layout.astro';
import EsempioCF from '../components/EsempioCF.astro';
import SearchPaesi from '../components/SearchPaesi';
import { paesiPerContinente, CONTINENTI } from '../data/paesiEsteri';

const continentIdMap: Record<string, string> = {
  'Europa': 'europa',
  'Africa': 'africa',
  'Asia': 'asia',
  'Americhe': 'americhe',
  'Oceania': 'oceania',
};

const continentCounts = Object.fromEntries(
  CONTINENTI.map(c => [c, paesiPerContinente.get(c)?.length ?? 0])
);

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Come si calcola il codice fiscale per chi è nato all'estero?",
      "acceptedAnswer": { "@type": "Answer", "text": "Per i nati all'estero la struttura del CF è identica a quella degli italiani, tranne per il codice catastale: al posto del comune di nascita si usa il codice del paese estero, che inizia sempre con Z (es. Z110 per la Francia, Z112 per la Germania)." }
    },
    {
      "@type": "Question",
      "name": "Dove trovo il codice catastale del mio paese di nascita?",
      "acceptedAnswer": { "@type": "Answer", "text": "Puoi trovarlo nella nostra tabella dei codici paesi esteri, oppure direttamente nel calcolatore selezionando 'Nato all'estero' e cercando il paese nel campo di ricerca." }
    },
    {
      "@type": "Question",
      "name": "Gli stranieri residenti in Italia hanno il codice fiscale?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sì. Tutti i cittadini stranieri che hanno rapporti con l'amministrazione italiana (lavoro, sanità, banca, acquisti immobiliari) devono richiedere il codice fiscale all'Agenzia delle Entrate o al Consolato italiano nel paese di origine." }
    },
    {
      "@type": "Question",
      "name": "Come si calcola il codice fiscale di un cittadino apolide?",
      "acceptedAnswer": { "@type": "Answer", "text": "Per gli apolidi e i rifugiati viene usato il codice Z000, che identifica la condizione di apolide nel sistema dell'Agenzia delle Entrate." }
    },
    {
      "@type": "Question",
      "name": "Quanti sono i codici Z per paesi esteri?",
      "acceptedAnswer": { "@type": "Answer", "text": "I codici catastali per paesi esteri sono 216, ciascuno assegnato dall'Agenzia delle Entrate. Iniziano tutti con la lettera Z seguita da tre cifre." }
    },
    {
      "@type": "Question",
      "name": "Qual è il codice catastale della Germania?",
      "acceptedAnswer": { "@type": "Answer", "text": "Il codice catastale della Germania è Z112. Viene usato nel codice fiscale per le persone nate in Germania." }
    },
    {
      "@type": "Question",
      "name": "Cosa significa 'codice fiscale estero'?",
      "acceptedAnswer": { "@type": "Answer", "text": "Il termine 'codice fiscale estero' indica il codice fiscale italiano calcolato per una persona nata all'estero. Non si tratta di un codice fiscale di un altro Paese, ma del normale CF italiano che usa un codice catastale Z (codice Belfiore) al posto del codice di un comune italiano. Ad esempio Z129 per la Romania, Z112 per la Germania, Z330 per il Marocco." }
    },
    {
      "@type": "Question",
      "name": "Come funziona il calcolo del codice fiscale per stranieri?",
      "acceptedAnswer": { "@type": "Answer", "text": "Il calcolo è identico a quello dei cittadini italiani: cognome (3 lettere), nome (3 lettere), data di nascita, codice del luogo di nascita e carattere di controllo. Per gli stranieri nati all'estero si usa il codice Z del paese di nascita. Per gli stranieri nati in Italia si usa il normale codice del comune." }
    },
    {
      "@type": "Question",
      "name": "Come trovo il codice catastale del mio paese di nascita?",
      "acceptedAnswer": { "@type": "Answer", "text": "Usa la barra di ricerca nella tabella qui sopra: puoi cercare per nome del paese o per codice Z." }
    },
  ],
};
---

<Layout
  title="Codice Fiscale Estero - Tabella Completa 216 Codici Catastali Paesi"
  description="Tabella completa dei 216 codici catastali (codici Z) dei paesi esteri per il codice fiscale italiano. Cerca il codice del tuo paese di nascita: Romania Z129, Germania Z112, Marocco Z330 e tutti gli altri."
  schemaJson={schemaFAQ}
  breadcrumbs={[{name:'Home',url:'/'},{name:"Nati all'Estero",url:'/codice-fiscale-stranieri/'}]}
>
  <div class="bg-gradient-to-b from-brand-navy to-brand-navy-light rounded-2xl p-8 mb-8">
    <nav class="text-xs mb-4">
      <a href="/" class="text-white/50 hover:text-white/70">Home</a>
      <span class="mx-1.5 text-white/50">&rsaquo;</span>
      <span class="text-white/80">Nati all'Estero</span>
    </nav>
    <h1 class="text-3xl font-heading font-bold text-white mb-2">Codice Fiscale Estero - Codici Catastali Paesi</h1>
    <p class="text-white/60 text-sm">Tabella completa dei 216 codici catastali (codici Z) per calcolare il codice fiscale di chi e nato all'estero</p>
    <div class="mt-4 inline-flex items-center gap-2 bg-white/10 border border-white/10 rounded-xl px-5 py-3 text-sm text-white/80">
      <strong class="text-white">Calcola subito il tuo CF</strong>: seleziona "Nato/a all'estero"
      <a href="/" class="font-semibold text-white hover:underline ml-1">Vai al calcolatore &rarr;</a>
    </div>
  </div>

  <div class="space-y-8 text-sm text-slate-700 leading-relaxed">

    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">Codice Fiscale Estero: Come si Calcola</h2>
      <p>
        Il calcolo del codice fiscale per chi è nato all'estero - cittadini stranieri residenti in Italia o italiani nati fuori dal territorio nazionale - segue la stessa procedura del codice fiscale ordinario: 3 lettere dal cognome, 3 dal nome, data di nascita codificata, codice del luogo di nascita e carattere di controllo.
      </p>
      <p class="mt-3">
        L'unica differenza nel calcolo del codice fiscale per stranieri e nati all'estero riguarda il <strong>codice catastale del luogo di nascita</strong>: al posto del codice di un comune italiano, si usa il <strong>codice del paese estero</strong> (detto anche codice Belfiore), che inizia sempre con la lettera <strong>Z</strong>. Ad esempio, Z110 per la Francia, Z112 per la Germania, Z129 per la Romania.
      </p>
    </section>

    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">Esempio Pratico</h2>
      <EsempioCF cognome="Schmidt" nome="Maria" sesso="F" giorno={15} mese={3} anno={1990} paese="Germania" codiceCatastale="Z112" />
    </section>

    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">I Codici Z - Come Funzionano</h2>
      <p>
        I codici per gli stati esteri sono definiti dall'<strong>Agenzia delle Entrate</strong>
        e iniziano tutti con la lettera <strong>Z</strong> seguita da tre cifre. Sono detti
        "codici Belfiore" per gli stati esteri.
      </p>
      <p class="mt-3">
        Ogni paese ha un codice unico che rimane stabile nel tempo. In caso di cambiamenti
        politici (es. paesi che si unificano o si dividono), l'AE assegna nuovi codici
        mantenendo quelli storici per i nati prima del cambiamento.
      </p>
    </section>

    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">Codici Fiscali Esteri Più Cercati</h2>
      <p class="mb-4">Ecco i codici catastali dei paesi esteri più richiesti per il calcolo del codice fiscale:</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {[
          { slug: 'romania', nome: 'Romania', codice: 'Z129' },
          { slug: 'albania', nome: 'Albania', codice: 'Z100' },
          { slug: 'germania', nome: 'Germania', codice: 'Z112' },
          { slug: 'svizzera', nome: 'Svizzera', codice: 'Z133' },
          { slug: 'francia', nome: 'Francia', codice: 'Z110' },
          { slug: 'regno-unito', nome: 'Regno Unito', codice: 'Z114' },
          { slug: 'marocco', nome: 'Marocco', codice: 'Z330' },
          { slug: 'argentina', nome: 'Argentina', codice: 'Z600' },
          { slug: 'ucraina', nome: 'Ucraina', codice: 'Z138' },
          { slug: 'brasile', nome: 'Brasile', codice: 'Z602' },
          { slug: 'stati-uniti', nome: 'Stati Uniti', codice: 'Z404' },
          { slug: 'ecuador', nome: 'Ecuador', codice: 'Z605' },
        ].map(p => (
          <a href={`/codice-fiscale-estero/${p.slug}/`}
            class="block p-3 bg-white border border-slate-200 rounded-xl hover:border-brand-blue-link transition-colors text-center">
            <div class="font-semibold text-sm text-brand-blue-link">{p.nome}</div>
            <div class="text-xs text-slate-500 font-mono mt-1">{p.codice}</div>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-4">Tabella Completa dei Codici Catastali Esteri</h2>

      <nav class="flex flex-wrap gap-2 mb-6">
        {CONTINENTI.map(c => (
          <a href={`#${continentIdMap[c]}`} class="bg-white border border-slate-200 text-slate-600 px-4 py-2 rounded-lg text-sm font-medium hover:border-brand-blue-link transition-colors">
            {c} ({continentCounts[c]})
          </a>
        ))}
      </nav>

      <SearchPaesi client:visible />

      {CONTINENTI.map(c => {
        const countries = paesiPerContinente.get(c) ?? [];
        const cid = continentIdMap[c];
        return (
          <div data-continente={cid}>
            <h3 id={cid} class="text-lg font-heading font-bold text-slate-800 mb-3 scroll-mt-20">
              {c} <span class="text-sm font-normal text-slate-500 ml-2">({countries.length} paesi)</span>
            </h3>
            <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-8">
              <div class="overflow-x-auto">
                <table class="text-sm border-collapse w-full">
                  <thead>
                    <tr class="bg-slate-50">
                      <th class="border-b border-slate-100 px-3 py-2 text-left text-xs font-semibold text-slate-500">Paese</th>
                      <th class="border-b border-slate-100 px-3 py-2 text-center w-24 text-xs font-semibold text-slate-500">Codice</th>
                    </tr>
                  </thead>
                  <tbody>
                    {countries.map(p => (
                      <tr id={p.codiceCatastale.toLowerCase()} data-paese={p.nome} data-codice={p.codiceCatastale}>
                        <td class="border-b border-slate-100 px-3 py-1.5">
                          {p.hasDedicatedPage ? (
                            <a href={`/codice-fiscale-estero/${p.slug}/`} class="text-brand-blue-link hover:underline font-medium">{p.nome}</a>
                          ) : (
                            <span class="font-medium">{p.nome}</span>
                          )}
                        </td>
                        <td class="border-b border-slate-100 px-3 py-1.5 text-center font-mono font-bold text-brand-navy-light">{p.codiceCatastale}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        );
      })}
    </section>

    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">Chi Deve Richiedere il Codice Fiscale</h2>
      <p>Il codice fiscale è obbligatorio per tutti i cittadini stranieri che in Italia:</p>
      <ul class="mt-2 space-y-1 list-disc list-inside text-slate-700">
        <li>Stipulano un contratto di lavoro</li>
        <li>Aprono un conto corrente bancario</li>
        <li>Accedono al Servizio Sanitario Nazionale</li>
        <li>Acquistano o affittano un immobile</li>
        <li>Svolgono qualsiasi atto con la Pubblica Amministrazione</li>
        <li>Sono iscritti all'AIRE (Anagrafe Italiani Residenti all'Estero)</li>
      </ul>
    </section>

    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">Come Richiedere il Codice Fiscale</h2>
      <p>I cittadini stranieri possono richiedere il codice fiscale:</p>
      <div class="mt-3 space-y-3">
        {[
          {
            title: 'In Italia',
            body: "Presso qualsiasi ufficio dell'Agenzia delle Entrate presentando un documento di identità valido. Il codice viene rilasciato immediatamente e gratuitamente.",
          },
          {
            title: "All'estero (italiani AIRE)",
            body: "Presso il Consolato o l'Ambasciata italiana nel paese di residenza. I cittadini italiani iscritti all'AIRE possono anche richiedere il CF online tramite il sito dell'Agenzia delle Entrate.",
          },
          {
            title: 'Calcolo preventivo',
            body: 'Puoi calcolare il tuo codice fiscale in anticipo con il nostro strumento. Il codice calcolato è valido nella quasi totalità dei casi (eccetto omocodia).',
          },
        ].map(({ title, body }) => (
          <div class="flex gap-3 bg-slate-50 rounded-lg p-4">
            <div class="w-2 h-2 rounded-full bg-brand-green mt-1.5 shrink-0"></div>
            <div>
              <p class="font-semibold text-slate-800">{title}</p>
              <p class="text-slate-600 mt-1">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-4">Approfondisci sul Codice Fiscale</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          { href: '/tabelle-codice-fiscale/', title: 'Tabelle Codice Fiscale', desc: 'Mesi, codici catastali e carattere di controllo' },
          { href: '/omocodia-codice-fiscale/', title: 'Omocodia del CF', desc: 'Quando il tuo CF ha lettere al posto delle cifre' },
          { href: '/verifica-codice-fiscale/', title: 'Verifica Codice Fiscale', desc: 'Controlla se un CF è formalmente corretto' },
          { href: '/come-leggere-codice-fiscale/', title: 'Come Leggere il CF', desc: 'Capisci ogni carattere del codice fiscale' },
          { href: '/cerca-codice-belfiore/', title: 'Cerca Codice Belfiore', desc: 'Tutti i codici catastali italiani ed esteri' },
          { href: '/codice-fiscale-estero/come-richiedere/', title: 'Come Richiedere il CF Estero', desc: "Procedura completa per chi vive all'estero" },
        ].map(({ href, title, desc }) => (
          <a href={href} class="block p-4 bg-white border border-slate-200 rounded-xl hover:border-brand-blue-link hover:shadow-sm transition-all">
            <div class="font-semibold text-sm text-brand-blue-link mb-1">{title} →</div>
            <div class="text-xs text-slate-500">{desc}</div>
          </a>
        ))}
      </div>
    </section>

  </div>

  <div class="my-10 min-h-[90px]"></div>

  <section>
    <h2 class="text-xl font-heading font-bold text-slate-800 mb-4">Domande Frequenti</h2>
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
      <div class="divide-y divide-slate-100">
        {[
          { q: "Come si calcola il codice fiscale per chi è nato all'estero?", a: "La struttura è identica ai nati in Italia. L'unica differenza è il codice catastale: si usa il codice del paese estero che inizia con Z (es. Z110 per la Francia, Z112 per la Germania, Z404 per gli USA)." },
          { q: "Dove trovo il codice catastale del mio paese?", a: "Nel nostro calcolatore, seleziona 'Nato all'estero' e cerca il paese nel campo di ricerca. Oppure consulta la tabella completa dei codici paesi esteri qui sopra." },
          { q: "Gli stranieri in Italia devono avere il CF?", a: "Sì, per qualsiasi rapporto con enti italiani (lavoro, banca, sanità, acquisti immobiliari). Si richiede all'Agenzia delle Entrate con un documento di identità." },
          { q: "Il CF cambia se cambio residenza?", a: "No. Il codice fiscale è basato sul luogo di nascita, non di residenza. Rimane invariato per tutta la vita, indipendentemente da dove si vive." },
          { q: "Quanti sono i codici Z per paesi esteri?", a: "I codici catastali per paesi esteri sono 216, ciascuno assegnato dall'Agenzia delle Entrate. Iniziano tutti con la lettera Z seguita da tre cifre." },
          { q: "Qual è il codice catastale della Germania?", a: "Il codice catastale della Germania è Z112. Viene usato nel codice fiscale per le persone nate in Germania." },
          { q: "Cosa significa 'codice fiscale estero'?", a: "Il termine 'codice fiscale estero' indica il codice fiscale italiano calcolato per una persona nata all'estero. Non si tratta di un codice fiscale di un altro Paese, ma del normale CF italiano che usa un codice catastale Z al posto del codice di un comune italiano." },
          { q: "Come funziona il calcolo del codice fiscale per stranieri?", a: "Il calcolo è identico a quello dei cittadini italiani: cognome (3 lettere), nome (3 lettere), data di nascita, codice del luogo di nascita e carattere di controllo. Per gli stranieri nati all'estero si usa il codice Z del paese di nascita. Per gli stranieri nati in Italia si usa il normale codice del comune." },
          { q: "Come trovo il codice catastale del mio paese di nascita?", a: "Usa la barra di ricerca nella tabella qui sopra: puoi cercare per nome del paese o per codice Z." },
        ].map(({ q, a }) => (
          <details class="group">
            <summary class="px-4 py-3 cursor-pointer font-medium text-sm text-slate-800 hover:bg-slate-50 list-none flex justify-between items-center">
              {q}
              <span class="text-slate-500 text-xs group-open:rotate-180 transition-transform">&#9660;</span>
            </summary>
            <p class="px-4 pb-3 text-sm text-slate-600">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <div class="mt-8 bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-2xl p-5 text-sm text-green-800 text-center">
    <strong>Calcola il tuo codice fiscale ora</strong>: seleziona "Nato/a all'estero" e inserisci i tuoi dati.
    <a href="/" class="ml-1 font-semibold hover:underline">Vai al calcolatore &rarr;</a>
  </div>
</Layout>

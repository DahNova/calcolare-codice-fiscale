---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import EsempioCF from '../../components/EsempioCF.astro';
import { paesiEsteri } from '../../data/paesiEsteri';
import { countryContent } from '../../data/countryContent';
import type { CountryContent } from '../../data/countryContent';
import { flagUrl, flagUrlSrcset } from '../../data/countryFlags';

const heroImports = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/countries-hero/*.webp',
  { eager: true }
);

export function getStaticPaths() {
  return countryContent.map(c => ({
    params: { slug: c.slug },
    props: { content: c },
  }));
}

function articoloDi(articolo: string, nome: string): string {
  switch (articolo) {
    case "l'": return `dell'${nome}`;
    case 'la': return `della ${nome}`;
    case 'le': return `delle ${nome}`;
    case 'gli': return `degli ${nome}`;
    case 'il': return `del ${nome}`;
    default: return `di ${nome}`;
  }
}

interface Props { content: CountryContent; }
const { content } = Astro.props;
const c = content;
const diPaese = articoloDi(c.articolo, c.nomeBreve);

// Parse example date
const mesiMap: Record<string, number> = {
  'gennaio':1,'febbraio':2,'marzo':3,'aprile':4,'maggio':5,'giugno':6,
  'luglio':7,'agosto':8,'settembre':9,'ottobre':10,'novembre':11,'dicembre':12,
};
const dataParts = c.esempioData.split(' ');
const esGiorno = parseInt(dataParts[0]);
const esMese = mesiMap[dataParts[1].toLowerCase()];
const esAnno = parseInt(dataParts[2]);
const esNomeParts = c.esempioNome.split(' ');
const esCognome = esNomeParts.length > 1 ? esNomeParts.slice(1).join(' ') : esNomeParts[0];
const esNome = esNomeParts[0];

// Related countries: up to 4 from same continent with dedicated pages
let related = paesiEsteri
  .filter(p => p.hasDedicatedPage && p.slug !== c.slug && p.continente === c.continente);
if (related.length < 4) {
  const others = paesiEsteri.filter(p => p.hasDedicatedPage && p.slug !== c.slug && p.continente !== c.continente);
  related = [...related, ...others].slice(0, 4);
} else {
  related = related.slice(0, 4);
}
const relatedContent = related.map(r => {
  const rc = countryContent.find(cc => cc.slug === r.slug);
  return { slug: r.slug, nome: rc?.nomeBreve || r.nome, codice: r.codiceCatastale };
});

// Schema
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `${c.codiceCatastale} codice fiscale: a quale stato corrisponde?`,
      "acceptedAnswer": { "@type": "Answer", "text": `${c.codiceCatastale} nel codice fiscale corrisponde a ${c.nomeCompleto}. È il codice catastale assegnato dall'Agenzia delle Entrate per identificare le persone nate ${c.preposizione} ${c.nomeBreve}.` }
    },
    {
      "@type": "Question",
      "name": `Qual è il codice catastale ${diPaese} nel codice fiscale?`,
      "acceptedAnswer": { "@type": "Answer", "text": `Il codice catastale ${diPaese} è ${c.codiceCatastale}. Viene usato nel codice fiscale italiano al posto del codice di un comune per le persone nate ${c.preposizione} ${c.nomeBreve}.` }
    },
    {
      "@type": "Question",
      "name": `Come si calcola il codice fiscale per chi è nato ${c.preposizione} ${c.nomeBreve}?`,
      "acceptedAnswer": { "@type": "Answer", "text": `Il calcolo segue la stessa procedura dei nati in Italia: 3 lettere dal cognome, 3 dal nome, data di nascita codificata, e il codice catastale ${c.codiceCatastale} (${c.nomeBreve}) al posto del codice di un comune italiano.` }
    },
    {
      "@type": "Question",
      "name": `${c.codiceCatastale} è il codice comune o il codice catastale ${diPaese}?`,
      "acceptedAnswer": { "@type": "Answer", "text": `${c.codiceCatastale} è sia il codice catastale sia il codice comune ${diPaese}. "Codice catastale", "codice comune" e "codice Belfiore" sono tre denominazioni diverse per lo stesso codice identificativo usato nel codice fiscale per indicare il luogo di nascita. Per chi è nato ${c.preposizione} ${c.nomeBreve}, il codice è ${c.codiceCatastale}.` }
    },
    ...(c.faqExtra ? [{
      "@type": "Question",
      "name": c.faqExtra.q,
      "acceptedAnswer": { "@type": "Answer", "text": c.faqExtra.a }
    }] : []),
  ],
};

const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `${c.codiceCatastale} Codice Fiscale ${c.nomeBreve} - Codice Catastale e Calcolo`,
  "description": `${c.codiceCatastale} è il codice catastale ${diPaese}: usalo per calcolare il codice fiscale di chi è nato ${c.preposizione} ${c.nomeBreve}. Esempio pratico con nome e cognome, procedura di richiesta e FAQ.`,
  "url": `https://www.calcolare-codice-fiscale.it/codice-fiscale-estero/${c.slug}/`,
  "inLanguage": "it",
  "datePublished": "2026-03-20",
  "dateModified": "2026-03-20",
  "author": { "@type": "Organization", "name": "Calcolare Codice Fiscale" },
  "publisher": { "@type": "Organization", "name": "Calcolare Codice Fiscale" },
};

const title = `${c.codiceCatastale} Codice Fiscale ${c.nomeBreve} - Codice Catastale e Calcolo`;
const description = `${c.codiceCatastale} è il codice catastale ${diPaese}: usalo per calcolare il codice fiscale di chi è nato ${c.preposizione} ${c.nomeBreve}. Esempio pratico con nome e cognome, procedura di richiesta e FAQ.`;

const flagSrc = flagUrl(c.slug, 'w40');
const flagSrcset = flagUrlSrcset(c.slug);
const flagAlt = `Bandiera ${diPaese}`;

const heroImage = heroImports[`/src/assets/countries-hero/${c.slug}.webp`]?.default;
const heroAlt = `Codice fiscale italiano per cittadini nati ${c.preposizione} ${c.nomeBreve} — scena d'archivio istituzionale con bandiere ${c.nomeBreve} e Italia, codice catastale ${c.codiceCatastale}`;
---

<Layout title={title} description={description} schemaJson={[schemaFAQ, schemaArticle]}
  breadcrumbs={[{name:'Home',url:'/'},{name:"Nati all'Estero",url:'/codice-fiscale-stranieri/'},{name:c.nomeBreve,url:`/codice-fiscale-estero/${c.slug}/`}]}>

  <!-- Gradient Header -->
  <div class="bg-gradient-to-b from-brand-navy to-brand-navy-light rounded-2xl p-8 mb-8">
    <nav class="text-xs mb-4">
      <a href="/" class="text-white/50 hover:text-white/70">Home</a>
      <span class="mx-1.5 text-white/50">&rsaquo;</span>
      <a href="/codice-fiscale-stranieri/" class="text-white/50 hover:text-white/70">Nati all'Estero</a>
      <span class="mx-1.5 text-white/50">&rsaquo;</span>
      <span class="text-white/80">{c.nomeBreve}</span>
    </nav>
    <h1 class="text-2xl sm:text-3xl font-heading font-bold text-white mb-1 flex items-center gap-3">
      {flagSrc && (
        <img
          src={flagSrc}
          srcset={flagSrcset || undefined}
          alt={flagAlt}
          width="40"
          height="30"
          loading="eager"
          decoding="async"
          class="inline-block shrink-0 rounded-sm shadow-sm ring-1 ring-white/20"
          style="aspect-ratio: 4/3; object-fit: cover;"
        />
      )}
      <span>{c.codiceCatastale} Codice Fiscale - {c.nomeBreve}</span>
    </h1>
    <p class="text-white/60 text-sm mb-1">Il codice catastale (Belfiore) <span class="font-mono font-bold text-white/90">{c.codiceCatastale}</span> identifica {c.nomeCompleto} nel codice fiscale</p>
    <p class="text-white/50 text-sm">Calcolo, esempio pratico e guida per chi è nato {c.preposizione} {c.nomeBreve}</p>
    <a href="/" class="mt-5 inline-flex items-center gap-2 bg-white/10 border border-white/15 rounded-xl px-5 py-2.5 text-sm text-white hover:bg-white/15 transition-colors">
      Vai al calcolatore
      <span class="text-white/60">&rarr;</span>
    </a>
  </div>

  <div class="space-y-8 text-sm text-slate-600 leading-relaxed">

    <!-- Section: Il Codice Catastale -->
    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">{c.codiceCatastale}: Codice Fiscale {c.nomeBreve}</h2>
      <p>
        <strong>{c.codiceCatastale}</strong> è il codice catastale {diPaese} nel codice fiscale italiano.
        Chi è nato {c.preposizione} {c.nomeBreve} utilizza il codice {c.codiceCatastale} al posto del codice
        di un comune italiano. Questo codice occupa le posizioni 12-15 del codice fiscale
        (i 4 caratteri che identificano il luogo di nascita).
      </p>
      <p class="mt-3">
        I codici catastali per gli stati esteri iniziano tutti con la lettera <strong>Z</strong> e sono assegnati
        dall'Agenzia delle Entrate. Il codice {c.codiceCatastale} è univocamente associato a {c.nomeCompleto}
        e rimane stabile nel tempo.
      </p>
      <p class="mt-3">
        Il codice {c.codiceCatastale} è indicato anche come <strong>codice comune</strong> o <strong>codice Belfiore</strong> {diPaese}: si tratta di denominazioni diverse per lo stesso identificativo assegnato dall'Agenzia delle Entrate a ogni stato estero.
      </p>
    </section>

    <!-- Section: Esempio Pratico -->
    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">Esempio Pratico</h2>
      <EsempioCF
        cognome={esCognome}
        nome={esNome}
        sesso={c.esempioSesso}
        giorno={esGiorno}
        mese={esMese}
        anno={esAnno}
        paese={c.nomeBreve}
        codiceCatastale={c.codiceCatastale}
      />
    </section>

    {heroImage && (
      <figure class="my-2">
        <Image
          src={heroImage}
          alt={heroAlt}
          widths={[480, 768, 1024]}
          sizes="(max-width: 768px) 100vw, 768px"
          loading="lazy"
          decoding="async"
          class="w-full h-auto rounded-2xl ring-1 ring-slate-200 shadow-sm"
        />
      </figure>
    )}

    <!-- Section: Comunita in Italia -->
    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">Comunità {c.nomeBreve} in Italia</h2>
      <p>{c.comunita}</p>
    </section>

    <!-- Section: Come Richiedere -->
    <section>
      <h2 class="text-xl font-heading font-bold text-slate-800 mb-3">Come Richiedere il Codice Fiscale</h2>
      <p>Chi è nato {c.preposizione} {c.nomeBreve} può richiedere il codice fiscale:</p>
      <div class="mt-3 space-y-3">
        <div class="flex gap-3 bg-slate-50 rounded-lg p-4">
          <div class="w-2 h-2 rounded-full bg-brand-green mt-1.5 shrink-0"></div>
          <div>
            <p class="font-semibold text-slate-800">In Italia</p>
            <p class="text-slate-600 mt-1">Presso qualsiasi ufficio dell'Agenzia delle Entrate presentando un documento di identità valido. Il codice viene rilasciato immediatamente e gratuitamente.</p>
          </div>
        </div>
        <div class="flex gap-3 bg-slate-50 rounded-lg p-4">
          <div class="w-2 h-2 rounded-full bg-brand-green mt-1.5 shrink-0"></div>
          <div>
            <p class="font-semibold text-slate-800">All'estero</p>
            <p class="text-slate-600 mt-1">Presso il Consolato o l'Ambasciata italiana {c.preposizione} {c.nomeBreve}. I cittadini italiani iscritti all'AIRE possono richiederlo anche online tramite il sito dell'Agenzia delle Entrate.</p>
          </div>
        </div>
      </div>
    </section>

  </div>

  <div class="my-10 min-h-[90px]"></div>

  <!-- FAQ -->
  <section>
    <h2 class="text-xl font-heading font-bold text-slate-800 mb-4">Domande Frequenti</h2>
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
      <div class="divide-y divide-slate-100">
        {[
          { q: `${c.codiceCatastale} codice fiscale: a quale stato corrisponde?`, a: `${c.codiceCatastale} nel codice fiscale corrisponde a ${c.nomeCompleto}. È il codice catastale assegnato dall'Agenzia delle Entrate per identificare le persone nate ${c.preposizione} ${c.nomeBreve}.` },
          { q: `Qual è il codice catastale ${diPaese}?`, a: `Il codice catastale ${diPaese} è ${c.codiceCatastale}. Si usa nel codice fiscale per identificare le persone nate ${c.preposizione} ${c.nomeBreve}.` },
          { q: `Come si calcola il CF per chi è nato ${c.preposizione} ${c.nomeBreve}?`, a: `Il calcolo è identico a quello per i nati in Italia. L'unica differenza è il codice catastale: si usa ${c.codiceCatastale} al posto del codice di un comune italiano.` },
          { q: `${c.codiceCatastale} è il codice comune o il codice catastale ${diPaese}?`, a: `${c.codiceCatastale} è sia il codice catastale sia il codice comune ${diPaese}. "Codice catastale", "codice comune" e "codice Belfiore" sono tre denominazioni diverse per lo stesso codice identificativo usato nel codice fiscale per indicare il luogo di nascita. Per chi è nato ${c.preposizione} ${c.nomeBreve}, il codice è ${c.codiceCatastale}.` },
          ...(c.faqExtra ? [c.faqExtra] : []),
        ].map(({ q, a }) => (
          <details class="group">
            <summary class="px-4 py-3 cursor-pointer font-medium text-sm text-slate-800 hover:bg-slate-50 list-none flex justify-between items-center">
              {q}
              <span class="text-slate-500 text-xs group-open:rotate-180 transition-transform">&#9660;</span>
            </summary>
            <p class="px-4 pb-3 text-sm text-slate-600">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related countries -->
  <section class="mt-8">
    <h2 class="text-lg font-heading font-bold text-slate-800 mb-3">Codici Fiscali di Altri Paesi</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {relatedContent.map(r => (
        <a href={`/codice-fiscale-estero/${r.slug}/`}
          class="block p-3 bg-white border border-slate-200 rounded-xl hover:border-brand-blue-link transition-colors text-center">
          <div class="font-semibold text-sm text-brand-blue-link">{r.nome}</div>
          <div class="text-xs text-slate-500 font-mono mt-1">{r.codice}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <div class="mt-10 bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-2xl p-5 text-center">
    <p class="font-semibold text-green-800 mb-2">Calcola il tuo codice fiscale</p>
    <a href="/" class="inline-block bg-brand-green hover:bg-brand-green-hover text-white px-6 py-2.5 rounded-lg transition-colors font-medium text-sm">
      Vai al Calcolatore &rarr;
    </a>
  </div>
</Layout>

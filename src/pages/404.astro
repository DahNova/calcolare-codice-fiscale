---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina non trovata" description="La pagina richiesta non esiste.">
  <div class="flex flex-col items-center justify-center text-center py-20">
    <span class="text-[120px] font-heading font-extrabold text-slate-200 leading-none mb-4 select-none">404</span>
    <h1 class="text-2xl font-heading font-bold text-slate-800 mb-2">Pagina non trovata</h1>
    <p class="text-slate-500 mb-8">La pagina che stai cercando non esiste o è stata spostata.</p>
    <a href="/" class="inline-flex items-center gap-2 bg-brand-navy text-white font-heading font-semibold px-6 py-3 rounded-xl hover:bg-brand-navy-light transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Torna alla Home
    </a>
  </div>
</Layout>
